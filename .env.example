# Example environment variables for deployment
# Copy this file to `.env` and fill in with your actual values when deploying
# outside Lovable. Do NOT commit real secret keys to public repos.

VITE_SUPABASE_PROJECT_ID="your-project-id-here"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key-here"
VITE_SUPABASE_URL="https://your-project-id-here.supabase.co"
